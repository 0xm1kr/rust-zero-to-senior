# Copy this file to .env and fill in ONE of the API keys below.
# .env is gitignored.

# ──────────────── Google Gemini (recommended, free tier) ────────────────
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# ──────────────── Anthropic Claude ────────────────
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5

# ──────────────── OpenAI ────────────────
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ──────────────── Chat abuse protection (public deploys) ────────────────
# Per-IP limits for POST /api/chat. Set a limit to 0 to disable it.
# CHAT_RATE_PER_MIN=5
# CHAT_RATE_DAILY=50
# CHAT_MAX_MESSAGE_CHARS=4000
# CHAT_MAX_CODE_CHARS=16000
# CHAT_MAX_BODY_BYTES=65536
# TRUST_PROXY=1
